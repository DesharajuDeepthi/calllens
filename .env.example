# Copy to .env and fill in values — never commit .env

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=calllens
POSTGRES_USER=calllens
POSTGRES_PASSWORD=calllens_dev

# App-level DB user (used by workers/API — limited privileges)
POSTGRES_APP_USER=calllens_app
POSTGRES_APP_PASSWORD=calllens_app_dev

# Redis
REDIS_URL=redis://localhost:6379/0

# Demo tenant
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
DEFAULT_TENANT_SLUG=aegiscloud

# Source data path (absolute path to the raaw/ folder)
TRANSCRIPT_DATA_PATH=/Users/deepthidesharaju/Documents/Transcript Intelligence/data/raaw

# LLM
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0
CLASSIFIER_CONFIDENCE_THRESHOLD=0.7

# JWT — MCP auth (Phase 3)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-use-a-32-char-random-string

# Neo4j — knowledge graph (Phase 6)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=calllens_dev
NEO4J_AUTH=neo4j/calllens_dev

# Langfuse — LLM observability (Phase 5)
# Sign up free at https://cloud.langfuse.com, then fill in your keys
# Leave blank to disable (Langfuse is optional — pipeline works without it)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# OTEL — distributed tracing (Phase 5)
# Leave blank for console exporter (dev); set for Jaeger/etc in production
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# Eval thresholds (Phase 5)
EVAL_CLASSIFICATION_THRESHOLD=0.75
EVAL_SENTIMENT_THRESHOLD=0.60
EVAL_MIN_CALLS=100
EVAL_MIN_INSIGHTS_PER_PERSONA=1
EVAL_JUDGE_THRESHOLD=0.65
EVAL_JUDGE_SAMPLE_SIZE=5
